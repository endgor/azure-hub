{
  "name": "azure-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/validateData.js && node scripts/fetchEntraIdRolesIfPossible.js && npm run generate-ip-lookup-index && npm run generate-site-data && node scripts/generateSitemap.js && next build",
    "analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:preview": "opennextjs-cloudflare build && wrangler deploy --env preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "update-ip-data": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/updateIpData.ts",
    "update-rbac-data": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/updateRbacData.ts",
    "fetch-entraid-roles": "ts-node --project tsconfig.node.json scripts/fetchEntraIdRoles.ts",
    "generate-actions-index": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/generateActionsIndex.ts",
    "generate-site-data": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/generateSiteData.ts",
    "generate-ip-indexes": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/generateIpIndexes.ts",
    "generate-ip-lookup-index": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/generateIpLookupIndex.ts",
    "update-private-dns-zones": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/updatePrivateDnsZones.ts",
    "submit-indexnow": "ts-node --project tsconfig.node.json -r tsconfig-paths/register scripts/submitIndexNow.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.8.3",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "d3-geo": "^3.1.1",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "ip-cidr": "^4.0.2",
    "js-base64": "^3.7.8",
    "next": "^16.2.3",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-prism-plus": "^2.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "topojson-client": "^3.1.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@azure/identity": "^4.13.1",
    "@next/bundle-analyzer": "^16.2.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "wrangler": "^4.83.0"
  }
}
